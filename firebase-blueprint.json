{
  "entities": {
    "User": {
      "title": "UserProfile",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "username": { "type": "string" },
        "searchId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "username", "searchId", "createdAt"]
    },
    "FileTransfer": {
      "title": "FileTransfer",
      "description": "Information about sent file between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "fileId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "number" },
        "downloadUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "senderName", "receiverId", "fileId", "fileName", "fileSize", "downloadUrl", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/transfers/{transferId}": {
      "schema": { "$ref": "#/entities/FileTransfer" },
      "description": "Stores file transfers"
    }
  }
}
